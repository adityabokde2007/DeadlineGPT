rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.uid is string 
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 256
        && data.email is string && data.email.size() <= 256
        && data.provider is string && data.provider.size() <= 64;
    }

    function isValidTask(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 256
        && data.description is string && data.description.size() <= 2048
        && data.estimatedEffort is int && data.estimatedEffort >= 0
        && data.priority is string && (data.priority == 'low' || data.priority == 'medium' || data.priority == 'high' || data.priority == 'urgent' || data.priority == 'critical')
        && data.category is string && data.category.size() <= 128
        && data.status is string && (data.status == 'pending' || data.status == 'in-progress' || data.status == 'completed')
        && data.subtasks is list && data.subtasks.size() <= 100
        && data.deadline is timestamp
        && data.createdAt is timestamp;
    }

    function isValidScheduleItem(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.taskId is string && data.taskId.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.startTime is string && data.startTime.size() <= 32
        && data.endTime is string && data.endTime.size() <= 32
        && data.aiNote is string && data.aiNote.size() <= 2048;
    }

    function isValidUserPrefs(data) {
      return data.availableHoursPerDay is number 
        && data.availableHoursPerDay >= 0.0 && data.availableHoursPerDay <= 24.0
        && data.workingHoursStart is string && data.workingHoursStart.size() <= 32
        && data.workingHoursEnd is string && data.workingHoursEnd.size() <= 32;
    }

    function isValidActivityLog(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.action is string && (data.action == 'completed' || data.action == 'created' || data.action == 'missed')
        && data.taskTitle is string && data.taskTitle.size() <= 256
        && data.timestamp is timestamp;
    }

    // --- COLLECTION MATCH RULES ---

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isVerified() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isVerified() && userId == request.auth.uid && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'lastLogin']);
      allow delete: if false; // Profiles cannot be self-deleted in-app
    }

    // Tasks Collection
    match /tasks/{taskId} {
      allow get, list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(taskId) 
        && isValidTask(incoming()) 
        && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidId(taskId)
        && isValidTask(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'deadline', 'estimatedEffort', 'priority', 'category', 'status', 'subtasks']);
      allow delete: if isVerified() && isValidId(taskId)
        && existing().userId == request.auth.uid;
    }

    // Schedule Collection
    match /schedule/{scheduleId} {
      allow get, list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(scheduleId) && isValidScheduleItem(incoming());
      allow update: if isVerified() && isValidId(scheduleId)
        && isValidScheduleItem(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().taskId == existing().taskId
        && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'startTime', 'endTime', 'aiNote']);
      allow delete: if isVerified() && isValidId(scheduleId) && existing().userId == request.auth.uid;
    }

    // User Preferences Collection
    match /userPrefs/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isVerified() && userId == request.auth.uid && isValidUserPrefs(incoming());
      allow update: if isVerified() && userId == request.auth.uid 
        && isValidUserPrefs(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['availableHoursPerDay', 'workingHoursStart', 'workingHoursEnd']);
      allow delete: if isVerified() && userId == request.auth.uid;
    }

    // Activity Log Collection (Append-only / Immutable history)
    match /activityLog/{logId} {
      allow get, list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(logId) 
        && isValidActivityLog(incoming())
        && incoming().timestamp == request.time;
      allow update, delete: if false; // Completely immutable once recorded
    }

  }
}
